---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, summary, org, period, role, stack, metrics, before, after } = entry.data;
---

<Base title={title} description={summary}>
  <article class="prose">
    <a class="back" href="/#projects">← Projects</a>
    {org && <div class="card-org">{org}</div>}
    <h1>{title}</h1>
    <p class="summary">{summary}</p>

    <div class="metabar">
      {period && <span><b>Period</b> {period}</span>}
      {role && <span><b>Role</b> {role}</span>}
    </div>

    {stack.length > 0 && (
      <div class="chips" style="margin-bottom:1rem">
        {stack.map((s) => <span class="chip">{s}</span>)}
      </div>
    )}

    {metrics.length > 0 && (
      <ul>
        {metrics.map((m) => <li>{m}</li>)}
      </ul>
    )}

    {before && after && (
      <div class="ba">
        <div class="ba-col ba-before"><span class="ba-tag">Before</span>{before}</div>
        <div class="ba-arrow">→</div>
        <div class="ba-col ba-after"><span class="ba-tag">After</span>{after}</div>
      </div>
    )}

    <Content />
  </article>
</Base>
