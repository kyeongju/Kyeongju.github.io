---
import Base from '../../layouts/Base.astro';

// 멀티리전 글로벌 게임 인프라 패턴
const diagram = {
  groups: [
    { id: 'g_tokyo', label: 'Tokyo · ap-northeast-1', type: 'cloud', desc: '국내 런칭 리전 + Manage 허브 위치.' },
    { id: 'g_sg', label: 'Singapore · ap-southeast-1', type: 'cloud', desc: '글로벌 확장 리전(아시아).' },
    { id: 'g_us', label: 'Virginia · us-east-1', type: 'cloud', desc: '글로벌 확장 리전(북미).' },
  ],
  nodes: [
    { id: 'client', label: '글로벌 게이머', type: 'person', icon: 'users', layer: 0, col: 3.45,
      desc: '글로벌 사용자 — 게임 접속 트래픽과 클라이언트 패치 다운로드 진입점' },
    { id: 'tg', label: 'Terragrunt 모듈', sub: '리전별 변수만 차이', type: 'system', icon: 'layers', layer: 0, col: 0,
      desc: '기능: 리전 인프라를 코드로 복제(VPC·ALB·ASG·RDS·Redis·CloudFront 일괄)\n원칙: 리전별 차이를 변수로만 흡수해 신규 리전을 빠르게 확장' },

    { id: 'r53', label: 'Route53', sub: 'Public · Private DNS', type: 'network', icon: 'globe', layer: 1, col: 2.6,
      desc: '기능: 퍼블릭·프라이빗 DNS\n역할: 게이머를 가까운 리전으로 라우팅' },
    { id: 'cf', label: 'CloudFront + S3', sub: '클라이언트 패치', type: 'aws', icon: 'bucket', layer: 1, col: 4.3,
      desc: '기능: CDN(CloudFront) + S3 오리진\n역할: 게임 클라이언트 패치·정적 자산을 글로벌 배포' },

    { id: 'mgmt', label: 'Manage 허브', sub: 'Tokyo 관리 VPC', type: 'system', icon: 'box', layer: 2, col: 0,
      desc: '기능: 운영·배포 관리 VPC(Tokyo)\n연결: 모든 리전과 QA(Seoul)를 VPC Peering으로 잇는 중앙 허브' },
    { id: 'lb_t', label: 'ALB / NLB', type: 'network', icon: 'gateway', layer: 2, col: 1.45, group: 'g_tokyo',
      desc: '기능: ALB(HTTP) + NLB(TCP) 트래픽 진입\n구성: 리전별 여러 게임 월드(w01/w02/common) 분기' },
    { id: 'lb_s', label: 'ALB / NLB', type: 'network', icon: 'gateway', layer: 2, col: 3.45, group: 'g_sg',
      desc: '기능: ALB + NLB 트래픽 진입' },
    { id: 'lb_u', label: 'ALB / NLB', type: 'network', icon: 'gateway', layer: 2, col: 5.45, group: 'g_us',
      desc: '기능: ALB + NLB 트래픽 진입' },

    { id: 'ec2_t', label: 'EC2 · Auto Scaling', sub: '게임 서버군', type: 'aws', icon: 'box', layer: 3, col: 1.45, group: 'g_tokyo',
      desc: '기능: 게임 서버(EC2) + Auto Scaling Group\n원칙: CloudWatch 알람 기반 자동 확장, Launch Template로 표준화' },
    { id: 'ec2_s', label: 'EC2 · Auto Scaling', sub: '게임 서버군', type: 'aws', icon: 'box', layer: 3, col: 3.45, group: 'g_sg',
      desc: '기능: 게임 서버(EC2) + Auto Scaling Group' },
    { id: 'ec2_u', label: 'EC2 · Auto Scaling', sub: '게임 서버군', type: 'aws', icon: 'box', layer: 3, col: 5.45, group: 'g_us',
      desc: '기능: 게임 서버(EC2) + Auto Scaling Group' },

    { id: 'redis_t', label: 'ElastiCache Redis', type: 'data', icon: 'db', layer: 4, col: 1.0, group: 'g_tokyo',
      desc: '기능: 세션·캐시 계층(리전 내 지연 흡수)' },
    { id: 'rds_t', label: 'Aurora', sub: 'RDS Cluster', type: 'data', icon: 'db', layer: 4, col: 1.9, group: 'g_tokyo',
      desc: '기능: Aurora(RDS Cluster) — 계정·게임 영속 데이터' },
    { id: 'redis_s', label: 'ElastiCache Redis', type: 'data', icon: 'db', layer: 4, col: 3.0, group: 'g_sg',
      desc: '기능: 세션·캐시 계층' },
    { id: 'rds_s', label: 'Aurora', sub: 'RDS Cluster', type: 'data', icon: 'db', layer: 4, col: 3.9, group: 'g_sg',
      desc: '기능: Aurora(RDS Cluster)' },
    { id: 'redis_u', label: 'ElastiCache Redis', type: 'data', icon: 'db', layer: 4, col: 5.0, group: 'g_us',
      desc: '기능: 세션·캐시 계층' },
    { id: 'rds_u', label: 'Aurora', sub: 'RDS Cluster', type: 'data', icon: 'db', layer: 4, col: 5.9, group: 'g_us',
      desc: '기능: Aurora(RDS Cluster)' },

    { id: 'logs', label: 'Filebeat / Logstash', sub: '로그 파이프라인', type: 'service', icon: 'doc', layer: 5, col: 3.45,
      desc: '기능: 리전 게임 서버 로그 수집·정규화\n호출·사용: 각 리전 인스턴스 로그 수집' },
    { id: 'opensearch', label: 'OpenSearch', sub: '실시간 분석·DataStream', type: 'service', icon: 'search', layer: 6, col: 3.45,
      desc: '기능: 실시간 로그 분석으로 장애 대응 시간 단축\n개선: DataStream 전환·인덱스 튜닝' },
  ],
  edges: [
    { from: 'client', to: 'r53', label: '게임 접속', kind: 'sync' },
    { from: 'client', to: 'cf', label: '패치 다운로드', kind: 'data' },

    { from: 'r53', to: 'lb_t', label: 'DNS 라우팅', kind: 'sync' },
    { from: 'r53', to: 'lb_s', kind: 'sync' },
    { from: 'r53', to: 'lb_u', kind: 'sync' },

    { from: 'lb_t', to: 'ec2_t', label: '트래픽', kind: 'sync' },
    { from: 'lb_s', to: 'ec2_s', kind: 'sync' },
    { from: 'lb_u', to: 'ec2_u', kind: 'sync' },

    { from: 'ec2_t', to: 'redis_t', label: '세션·캐시', kind: 'sync' },
    { from: 'ec2_t', to: 'rds_t', label: 'Aurora', kind: 'sync' },
    { from: 'ec2_s', to: 'redis_s', kind: 'sync' },
    { from: 'ec2_s', to: 'rds_s', kind: 'sync' },
    { from: 'ec2_u', to: 'redis_u', kind: 'sync' },
    { from: 'ec2_u', to: 'rds_u', kind: 'sync' },

    { from: 'tg', to: 'lb_t', label: 'provision', kind: 'sync' },
    { from: 'tg', to: 'lb_s', kind: 'sync' },
    { from: 'tg', to: 'lb_u', kind: 'sync' },

    { from: 'mgmt', to: 'lb_t', label: 'VPC Peering', kind: 'async' },
    { from: 'mgmt', to: 'lb_s', kind: 'async' },
    { from: 'mgmt', to: 'lb_u', kind: 'async' },
    { from: 'lb_t', to: 'lb_s', kind: 'async' },
    { from: 'lb_t', to: 'lb_u', kind: 'async' },

    { from: 'ec2_t', to: 'logs', label: 'logs', kind: 'data' },
    { from: 'ec2_s', to: 'logs', kind: 'data' },
    { from: 'ec2_u', to: 'logs', kind: 'data' },
    { from: 'logs', to: 'opensearch', kind: 'data' },
  ],
  flows: [
    {
      id: 'f_request', label: '요청 처리 경로', muteEdges: true,
      desc: '게이머 요청이 Route53 DNS를 거쳐 리전 ALB/NLB → 게임 서버(EC2·ASG) → Aurora·Redis로 처리된다.',
      steps: [
        { from: 'client', to: 'r53', note: '게이머 게임 접속(DNS)' },
        { from: 'r53', to: 'lb_t', note: '가까운 리전 ALB/NLB로 라우팅' },
        { from: 'lb_t', to: 'ec2_t', note: '게임 서버(EC2·Auto Scaling)로 분산' },
        { from: 'ec2_t', to: 'redis_t', note: '세션·캐시는 Redis' },
        { from: 'ec2_t', to: 'rds_t', note: '영속 데이터는 Aurora' },
      ],
    },
    {
      id: 'f_global', label: '글로벌 리전 확장', muteEdges: true,
      desc: 'Terragrunt 모듈로 국내(Tokyo) 런칭 후 동일 구성을 다른 리전으로 복제.',
      steps: [
        { from: 'tg', to: 'lb_t', note: '국내(Tokyo) 리전 구성' },
        { from: 'tg', to: 'lb_s', note: '동일 모듈로 Singapore 확장' },
        { from: 'tg', to: 'lb_u', note: '동일 모듈로 Virginia 확장' },
      ],
    },
    {
      id: 'f_peering', label: 'VPC Peering 메시', muteEdges: true,
      desc: 'Tokyo의 Manage 허브가 모든 리전·QA(Seoul)와 Peering하고, Tokyo 리전이 Singapore·Virginia와 추가로 연결된다.',
      steps: [
        { from: 'mgmt', to: 'lb_t', note: 'Manage → Tokyo' },
        { from: 'mgmt', to: 'lb_s', note: 'Manage → Singapore' },
        { from: 'mgmt', to: 'lb_u', note: 'Manage → Virginia' },
        { from: 'lb_t', to: 'lb_s', note: 'Tokyo → Singapore' },
        { from: 'lb_t', to: 'lb_u', note: 'Tokyo → Virginia' },
      ],
    },
    {
      id: 'f_patch', label: '클라이언트 패치 배포', muteEdges: true,
      desc: '게임 클라이언트 패치는 CloudFront(+S3)로 글로벌 배포한다.',
      steps: [
        { from: 'client', to: 'cf', note: 'CloudFront + S3에서 패치 다운로드' },
      ],
    },
    {
      id: 'f_logs', label: '실시간 로그 분석', muteEdges: true,
      desc: '각 리전 게임 서버 로그가 파이프라인을 거쳐 OpenSearch에서 실시간 분석된다.',
      steps: [
        { from: 'ec2_t', to: 'logs', note: '리전 로그를 Filebeat/Logstash로 수집' },
        { from: 'logs', to: 'opensearch', note: 'OpenSearch에서 실시간 분석(대응시간 30%↓)' },
      ],
    },
  ],
};
---

<Base title="멀티리전 글로벌 게임 인프라 (인터랙티브)" description="국내 런칭 후 글로벌 멀티리전으로 확장하는 게임 인프라 패턴 — 인터랙티브 다이어그램">
  <link rel="stylesheet" href="/arch/arch.css" />
  <style is:global>
    :root {
      --background: 0 0% 100%; --foreground: 240 10% 4%; --card: 0 0% 100%; --popover: 0 0% 100%;
      --muted: 240 5% 96%; --muted-foreground: 240 4% 46%; --border: 240 6% 90%; --accent: 240 5% 96%;
      --primary: 240 6% 13%; --primary-foreground: 0 0% 100%; --secondary: 240 5% 95%; --secondary-foreground: 240 6% 28%;
      --radius: 0.6rem; --arch-flow: 221 83% 53%;
      --arch-person: 222 14% 46%; --arch-service: 235 60% 56%; --arch-ai: 174 62% 38%; --arch-security: 352 68% 52%;
      --arch-data: 275 52% 56%; --arch-network: 202 85% 46%; --arch-aws: 28 85% 52%; --arch-external: 38 92% 50%;
    }
    body:has(.arch) .content main { max-width: 1180px; }
    .role-legend { display: flex; gap: .45rem 1rem; flex-wrap: wrap; margin: .2rem 0 1.2rem; font-size: .78rem; color: hsl(var(--muted-foreground)); }
    .role-legend span { display: inline-flex; align-items: center; gap: .34rem; }
    .role-legend i { width: 11px; height: 11px; border-radius: 3px; }
  </style>

  <article class="prose">
    <a class="back" href="/architecture">← Architecture</a>
    <h1>멀티리전 글로벌 게임 인프라 (인터랙티브)</h1>
    <p class="summary">대항해시대(UWO) Terraform/Terragrunt 코드를 기반으로 한 멀티리전 글로벌 게임 인프라 — Route53·CloudFront 글로벌 엣지, 리전별 ALB/NLB·EC2 Auto Scaling·Aurora·Redis, Manage 허브 VPC Peering 메시, 실시간 로그 분석까지의 실제 구성입니다.</p>

    <p>"리전은 Terragrunt로 복제하고, VPC는 Manage 허브로 잇고, 장애는 로그가 먼저 말하게 한다." 게이머 요청은 <strong>Route53 DNS</strong>로 가까운 리전에 라우팅되어 <strong>ALB/NLB → EC2(Auto Scaling) 게임 서버 → Aurora·Redis</strong>로 처리되고, 클라이언트 패치는 <strong>CloudFront+S3</strong>로 배포됩니다. Tokyo의 <strong>Manage 허브</strong>가 모든 리전·QA를 VPC Peering으로 연결하며, 각 리전 로그는 Filebeat/Logstash를 거쳐 OpenSearch에서 실시간 분석됩니다. 상단 버튼으로 <strong>요청 처리</strong>, <strong>리전 확장</strong>, <strong>VPC Peering</strong>, <strong>패치 배포</strong>, <strong>로그 분석</strong> 경로를 재생할 수 있습니다.</p>

    <div class="role-legend">
      <span><i style="background:hsl(222 14% 46%)"></i>게이머</span>
      <span><i style="background:hsl(240 6% 13%)"></i>Terragrunt · Manage 허브</span>
      <span><i style="background:hsl(202 85% 46%)"></i>Route53 · ALB/NLB · Peering</span>
      <span><i style="background:hsl(28 85% 52%)"></i>EC2 · CloudFront</span>
      <span><i style="background:hsl(275 52% 56%)"></i>데이터(Aurora · Redis)</span>
      <span><i style="background:hsl(235 60% 56%)"></i>로그 파이프라인</span>
    </div>

    <div class="arch" data-wide><script type="application/json" is:inline set:html={JSON.stringify(diagram)}></script></div>
  </article>

  <script is:inline src="/arch/arch.js"></script>
</Base>
