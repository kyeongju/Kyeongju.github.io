---
import Base from '../../layouts/Base.astro';

// ── Diagram A: 오케스트레이션 & 도구 ──
const orchestration = {
  groups: [
    { id: 'g_agents', label: 'Domain Agents', type: 'default', desc: '도메인별 책임을 나눠 갖는 에이전트. 각자 Gateway로 도구를 호출한다.' },
    { id: 'g_tools', label: 'Lambda MCP Tools (도메인별)', type: 'cloud', desc: 'Gateway가 라우팅하는 서버리스 도구 묶음. 도메인별로 분리.' },
  ],
  nodes: [
    { id: 'user', label: 'User / Frontend', sub: 'AGUI', type: 'person', icon: 'user', layer: 0, col: 2,
      desc: '기능: 자연어로 인프라 운영·비용·보안 질의\n호출·사용: AGUI 프로토콜로 Supervisor 호출\n산출: 통합 인사이트 응답' },
    { id: 'supervisor', label: 'Supervisor Agent', sub: '의도 라우팅·결과 집약', type: 'system', icon: 'workflow', layer: 1, col: 2,
      desc: '기능: 의도 파악 → 도메인 에이전트 라우팅 → 결과 집약\n호출·사용: A2A로 도메인 에이전트, Bedrock 추론, Memory 참조' },
    { id: 'memory', label: 'AgentCore Memory', sub: 'session/knowledge/prefs', type: 'data', icon: 'db', layer: 2, col: 0,
      desc: '기능: 세션·지식·사용자 선호 저장\n호출·사용: Supervisor·에이전트가 컨텍스트로 참조' },
    { id: 'devops', label: 'DevOps Agent', type: 'ai', icon: 'bot', layer: 2, col: 1, group: 'g_agents',
      desc: '기능: 상태 점검·근본원인 분석·조치\n서브에이전트: health_check · rca · remediation' },
    { id: 'finops', label: 'FinOps Agent', type: 'ai', icon: 'bot', layer: 2, col: 2, group: 'g_agents',
      desc: '기능: 비용 수집·이상탐지·최적화·리포트\n서브에이전트: cost_collector · anomaly_detector · optimizer_advisor · cleanops · report_writer' },
    { id: 'secops', label: 'SecOps Agent', type: 'ai', icon: 'bot', layer: 2, col: 3, group: 'g_agents',
      desc: '기능: 취약점 분석\n서브에이전트: vuln_analyst' },
    { id: 'bedrock', label: 'Bedrock Claude', sub: 'Opus/Sonnet/Haiku', type: 'ai', icon: 'sparkles', layer: 2, col: 4,
      desc: '기능: 작업 난이도별 멀티모델 추론\n호출·사용: Supervisor·도메인 에이전트가 LLM 추론에 사용' },
    { id: 'gateway', label: 'AgentCore Gateway', sub: '도메인별', type: 'network', icon: 'gateway', layer: 3, col: 2,
      desc: '기능: 에이전트의 도구 호출 진입점\n호출·사용: 도메인별 Lambda 도구로 라우팅, VPC Endpoint 프라이빗 통제' },
    { id: 't_common', label: 'Common Tools', sub: 'Resources·GitLab·Jira', type: 'aws', icon: 'plug', layer: 4, col: 0.5, group: 'g_tools',
      desc: '기능: 공통 도구\n구성: AWS Resources · GitLab · Jira/Confluence' },
    { id: 't_devops', label: 'DevOps Tools', sub: 'GitLab·Monitoring', type: 'aws', icon: 'plug', layer: 4, col: 1.5, group: 'g_tools',
      desc: '기능: DevOps 도구\n구성: GitLab · Monitoring' },
    { id: 't_finops', label: 'FinOps Tools', sub: 'Cost·Optimizer·Terraform', type: 'aws', icon: 'plug', layer: 4, col: 2.5, group: 'g_tools',
      desc: '기능: FinOps 도구\n구성: Cost Analytics/Inquiry/Report · Idle Resources · Optimizer · Terraform' },
    { id: 't_secops', label: 'SecOps Tools', sub: 'Inspector·NVD', type: 'aws', icon: 'plug', layer: 4, col: 3.5, group: 'g_tools',
      desc: '기능: SecOps 도구\n구성: Infra Inspector · NVD Vulnerability' },
    { id: 'aws', label: 'AWS 리소스', sub: 'EKS·EC2·RDS·CUR', type: 'external', icon: 'cloud', layer: 5, col: 2,
      desc: '기능: 실제 운영 대상·데이터 소스\n호출·사용: 도구가 조회/조치' },
  ],
  edges: [
    { from: 'user', to: 'supervisor', label: 'AGUI', kind: 'sync' },
    { from: 'supervisor', to: 'devops', label: 'A2A', kind: 'async' },
    { from: 'supervisor', to: 'finops', label: 'A2A', kind: 'async' },
    { from: 'supervisor', to: 'secops', label: 'A2A', kind: 'async' },
    { from: 'supervisor', to: 'bedrock', label: 'LLM', kind: 'async' },
    { from: 'supervisor', to: 'memory', label: 'context', kind: 'data' },
    { from: 'devops', to: 'gateway', kind: 'sync' },
    { from: 'finops', to: 'gateway', kind: 'sync' },
    { from: 'secops', to: 'gateway', kind: 'sync' },
    { from: 'gateway', to: 't_common', kind: 'sync' },
    { from: 'gateway', to: 't_devops', kind: 'sync' },
    { from: 'gateway', to: 't_finops', kind: 'sync' },
    { from: 'gateway', to: 't_secops', kind: 'sync' },
    { from: 't_finops', to: 'aws', label: 'query', kind: 'data' },
    { from: 't_devops', to: 'aws', kind: 'data' },
    { from: 't_secops', to: 'aws', kind: 'data' },
    { from: 't_common', to: 'aws', kind: 'data' },
  ],
  flows: [
    {
      id: 'f_query', label: '질의 → 도구 실행', muteEdges: true,
      desc: '사용자 질의가 Supervisor 라우팅을 거쳐 도메인 에이전트의 도구 실행으로 이어지는 경로.',
      steps: [
        { from: 'user', to: 'supervisor', note: '사용자 질의 — AGUI로 Supervisor 수신' },
        { from: 'supervisor', to: 'finops', note: '의도 파악 후 도메인 에이전트로 A2A 라우팅' },
        { from: 'finops', to: 'gateway', note: '에이전트가 Gateway로 도구 호출' },
        { from: 'gateway', to: 't_finops', note: '도메인 Lambda 도구 실행(서버리스)' },
        { from: 't_finops', to: 'aws', note: 'AWS 리소스 조회 — CUR/EC2/RDS' },
      ],
    },
  ],
};

// ── Diagram B: 도메인 에이전트 ↔ 서브에이전트 ──
const subagents = {
  groups: [
    { id: 'g_dv', label: 'DevOps Sub-agents', type: 'default' },
    { id: 'g_fo', label: 'FinOps Sub-agents', type: 'default' },
    { id: 'g_so', label: 'SecOps Sub-agents', type: 'default' },
  ],
  nodes: [
    { id: 'sup', label: 'Supervisor Agent', type: 'system', icon: 'workflow', layer: 0, col: 4 },
    { id: 'dv', label: 'DevOps Agent', type: 'ai', icon: 'bot', layer: 1, col: 1 },
    { id: 'fo', label: 'FinOps Agent', type: 'ai', icon: 'bot', layer: 1, col: 5 },
    { id: 'so', label: 'SecOps Agent', type: 'ai', icon: 'bot', layer: 1, col: 8 },
    { id: 'health', label: 'health_check', type: 'service', icon: 'monitor', layer: 2, col: 0, group: 'g_dv', desc: '기능: 리소스·서비스 상태 점검' },
    { id: 'rca', label: 'rca', type: 'service', icon: 'search', layer: 2, col: 1, group: 'g_dv', desc: '기능: 근본원인 분석(Root Cause Analysis)' },
    { id: 'rem', label: 'remediation', type: 'service', icon: 'wrench', layer: 2, col: 2, group: 'g_dv', desc: '기능: 조치·복구 수행' },
    { id: 'collector', label: 'cost_collector', type: 'service', icon: 'chart', layer: 2, col: 3, group: 'g_fo', desc: '기능: 비용 데이터 수집' },
    { id: 'anomaly', label: 'anomaly_detector', type: 'service', icon: 'bell', layer: 2, col: 4, group: 'g_fo', desc: '기능: 비용 이상 탐지' },
    { id: 'optimizer', label: 'optimizer_advisor', type: 'service', icon: 'zap', layer: 2, col: 5, group: 'g_fo', desc: '기능: 자원 최적화 권고(RI/Savings 등)' },
    { id: 'cleanops', label: 'cleanops', type: 'service', icon: 'package', layer: 2, col: 6, group: 'g_fo', desc: '기능: 유휴 자원 정리' },
    { id: 'report', label: 'report_writer', type: 'service', icon: 'doc', layer: 2, col: 7, group: 'g_fo', desc: '기능: 비용 리포트 생성' },
    { id: 'vuln', label: 'vuln_analyst', type: 'service', icon: 'shield', layer: 2, col: 8, group: 'g_so', desc: '기능: 취약점(CVE) 분석' },
  ],
  edges: [
    { from: 'sup', to: 'dv', label: 'A2A', kind: 'async' },
    { from: 'sup', to: 'fo', label: 'A2A', kind: 'async' },
    { from: 'sup', to: 'so', label: 'A2A', kind: 'async' },
    { from: 'dv', to: 'health', kind: 'sync' },
    { from: 'dv', to: 'rca', kind: 'sync' },
    { from: 'dv', to: 'rem', kind: 'sync' },
    { from: 'fo', to: 'collector', kind: 'sync' },
    { from: 'fo', to: 'anomaly', kind: 'sync' },
    { from: 'fo', to: 'optimizer', kind: 'sync' },
    { from: 'fo', to: 'cleanops', kind: 'sync' },
    { from: 'fo', to: 'report', kind: 'sync' },
    { from: 'so', to: 'vuln', kind: 'sync' },
  ],
  flows: [],
};
---

<Base title="AgentCore 멀티 에이전트 (인터랙티브)" description="Bedrock AgentCore 계층형 멀티 에이전트 아키텍처 — 오케스트레이션과 서브에이전트 구성">
  <link rel="stylesheet" href="/arch/arch.css" />
  <style is:global>
    :root {
      --background: 0 0% 100%; --foreground: 240 10% 4%; --card: 0 0% 100%; --popover: 0 0% 100%;
      --muted: 240 5% 96%; --muted-foreground: 240 4% 46%; --border: 240 6% 90%; --accent: 240 5% 96%;
      --primary: 240 6% 13%; --primary-foreground: 0 0% 100%; --secondary: 240 5% 95%; --secondary-foreground: 240 6% 28%;
      --radius: 0.6rem; --arch-flow: 221 83% 53%;
      --arch-person: 222 14% 46%; --arch-service: 235 60% 56%; --arch-ai: 174 62% 38%; --arch-security: 352 68% 52%;
      --arch-data: 275 52% 56%; --arch-network: 202 85% 46%; --arch-aws: 28 85% 52%; --arch-external: 38 92% 50%;
    }
    body:has(.arch) .content main { max-width: 1180px; }
    .role-legend { display: flex; gap: .45rem 1rem; flex-wrap: wrap; margin: .2rem 0 1.2rem; font-size: .78rem; color: hsl(var(--muted-foreground)); }
    .role-legend span { display: inline-flex; align-items: center; gap: .34rem; }
    .role-legend i { width: 11px; height: 11px; border-radius: 3px; }
  </style>

  <article class="prose">
    <a class="back" href="/architecture">← Architecture</a>
    <h1>AgentCore 멀티 에이전트 (인터랙티브)</h1>
    <p class="summary">Bedrock AgentCore 기반 계층형 에이전트 구조. 노드 클릭(설명)·플로우 재생·스텝 포커스가 가능합니다.</p>

    <div class="role-legend">
      <span><i style="background:hsl(222 14% 46%)"></i>사용자</span>
      <span><i style="background:hsl(240 6% 13%)"></i>Supervisor</span>
      <span><i style="background:hsl(174 62% 38%)"></i>도메인 에이전트·LLM</span>
      <span><i style="background:hsl(235 60% 56%)"></i>서브에이전트</span>
      <span><i style="background:hsl(202 85% 46%)"></i>게이트웨이</span>
      <span><i style="background:hsl(28 85% 52%)"></i>도구(AWS)</span>
      <span><i style="background:hsl(275 52% 56%)"></i>저장소</span>
    </div>

    <h2>1. 오케스트레이션 &amp; 도구</h2>
    <div class="arch" data-wide><script type="application/json" is:inline set:html={JSON.stringify(orchestration)}></script></div>

    <h2>2. 도메인 에이전트 ↔ 서브에이전트</h2>
    <div class="arch" data-wide><script type="application/json" is:inline set:html={JSON.stringify(subagents)}></script></div>
  </article>

  <script is:inline src="/arch/arch.js"></script>
</Base>
