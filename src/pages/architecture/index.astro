---
import Base from '../../layouts/Base.astro';
import { ARCHITECTURES } from '../../config';
---

<Base title="Architecture" description="재사용 가능한 아키텍처 설계 패턴과 인터랙티브 다이어그램">
  <section class="hero" style="padding-bottom:1rem">
    <h1 style="font-size:1.9rem">Architecture</h1>
    <p class="tagline">재사용 가능한 설계 패턴 — 노드 클릭·플로우 재생이 되는 인터랙티브 다이어그램</p>
  </section>

  <section>
    <div class="card-grid">
      {
        ARCHITECTURES.map((a) => (
          <a class="card" href={a.href}>
            <h3>{a.title}</h3>
            <p>{a.summary}</p>
            <div class="chips">
              {a.tags.map((t) => <span class="chip">{t}</span>)}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Base>
